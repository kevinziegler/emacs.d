(defun kdz/quick-gif ()
  (interactive)
  (let* ((key (completing-read "Select a GIF: " kdz-quick-gifs nil t))
         (url (alist-get key kdz-quick-gifs nil nil #'equal)))
    (kill-new url)
    (message "Copied GIF link: %s" url)))
